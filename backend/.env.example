# Backend Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Model Configuration
# Use 'cpu' or 'cuda' (GPU)
DEVICE=cpu

# Model Selection (will try in order)
# Options: tarteel_whisper, wav2vec2, whisper_pipeline, mock
PREFERRED_MODEL=tarteel_whisper

# Logging
LOG_LEVEL=INFO

# Quran API
QURAN_API_URL=http://api.alquran.cloud/v1
ENABLE_API_FETCH=True

# Cache Settings
CACHE_DIR=cache
ENABLE_CACHE=True
